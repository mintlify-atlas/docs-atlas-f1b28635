  "keyFeatures": [
    "Real-time global intelligence with 100+ curated news feeds",
    "Interactive 3D globe with 40+ toggleable data layers",
    "AI-powered intelligence synthesis with local LLM support",
    "Live military flight and naval vessel tracking",
    "Country Instability Index with multi-signal analysis",
    "Proto-first API architecture with 20+ typed services",
    "Native desktop app for macOS, Windows, and Linux",
    "Multiple themed variants (geopolitics, tech, finance, happy news)",
    "Multilingual support with 16 languages",
    "Progressive Web App with offline capabilities"
  ],
  "publicApiSurface": [
    "ConflictService - ACLED events, UCDP data, humanitarian summaries",
    "MilitaryService - Military bases, aircraft tracking, theater posture",
    "MaritimeService - AIS vessel tracking, USNI fleet intelligence",
    "AviationService - Airport delays, flight monitoring",
    "IntelligenceService - Country briefs, hotspot detection, threat classification",
    "NewsService - RSS aggregation, feed management, entity extraction",
    "MarketService - Crypto prices, market signals, prediction markets",
    "CyberService - Threat intelligence, IOC geolocation, APT tracking",
    "InfrastructureService - Cables, pipelines, datacenters, ports",
    "ClimateService - Climate anomalies, weather alerts",
    "SeismologyService - Earthquake monitoring, natural disasters",
    "DisplacementService - Refugee flows, humanitarian data",
    "PredictionService - Polymarket integration, forecast aggregation",
    "EconomicService - Government spending, economic indicators",
    "TradeService - WTO data, trade routes, tariff tracking"
  ]
